{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agentdeck",
  "version": "0.1.0",
  "identifier": "dev.enzo.agentdeck",
  "build": {
    "frontendDist": "../../ui/dist",
    "beforeBuildCommand": "npm --prefix ../../ui run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "agentdeck",
        "width": 380,
        "height": 460,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
